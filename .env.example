# MongoDB 连接字符串
MONGODB_URI=mongodb://localhost:27017/tiku

# JWT 密钥
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# 服务器端口
PORT=3000

# CORS 允许的源（逗号分隔）
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://tiku.020417.xyz,https://020417.xyz

# 小程序专用接口每分钟请求上限
MINIPROGRAM_RATE_LIMIT=90

# Web GitHub OAuth 登录
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# 邮件配置（可选）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password
SMTP_FROM=题库系统 <your_email@example.com>
